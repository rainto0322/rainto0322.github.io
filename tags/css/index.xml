&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> :root {
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> --vw-screen: &lt;span style="color:#d3869b">768&lt;/span>;
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> }
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>}
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>@&lt;span style="color:#fe8019">media&lt;/span> &lt;span style="color:#fe8019">(&lt;/span>&lt;span style="color:#fb4934">max-width&lt;/span>&lt;span style="color:#fe8019">:&lt;/span> &lt;span style="color:#fb4934">767px&lt;/span>&lt;span style="color:#fe8019">)&lt;/span> {
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> :root {
