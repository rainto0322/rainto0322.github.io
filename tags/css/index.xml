&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> &lt;span style="color:#fe8019">line-height&lt;/span>: &lt;span style="color:#fabd2f">calc&lt;/span>(&lt;span style="color:#d3869b">20&lt;/span> &lt;span style="color:#fe8019">/&lt;/span> &lt;span style="color:#fabd2f">var&lt;/span>(&lt;span style="color:#fe8019">--&lt;/span>vw&lt;span style="color:#fe8019">-&lt;/span>&lt;span style="color:#fe8019">screen&lt;/span>) &lt;span style="color:#fe8019">*&lt;/span> &lt;span style="color:#d3869b">100&lt;/span> &lt;span style="color:#fe8019">*&lt;/span> &lt;span style="color:#d3869b">1&lt;/span>&lt;span style="color:#fabd2f">vw&lt;/span>);
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>}&lt;/span>&lt;/span>&lt;/code>&lt;/pre>
