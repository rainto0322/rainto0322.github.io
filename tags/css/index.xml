 &lt;pre>&lt;code class="code">&lt;span style="display:flex;">&lt;span>:root {
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span> --vw-screen: &lt;span style="color:#d3869b">1440&lt;/span>;
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>}
&lt;/span>&lt;/span>&lt;span style="display:flex;">&lt;span>
